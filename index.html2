<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Civic Voice - Anonymous Community Board</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        @keyframes slideInUp {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .toast-enter {
            animation: slideInUp 0.3s ease-out forwards;
        }
    </style>
</head>
<body class="text-gray-800 antialiased min-h-screen flex-col">

    <nav class="bg-indigo-700 text-white shadow-md sticky top-0 z-10">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <svg class="h-8 w-8 mr-2 text-indigo-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                    </svg>
                    <span class="font-bold text-xl tracking-tight">Civic Voice</span>
                </div>
                <div class="flex items-center">
                    <span class="text-sm font-medium text-indigo-200 hidden sm:block">Speak Freely. Better Together.</span>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-col md:flex-row gap-8">
        
        <div class="w-full md:w-1/3">
            <div class="bg-white p-6 rounded-xl shadow-sm border-gray-100 sticky top-24">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Share Your Thoughts</h2>
                <p class="text-sm text-gray-500 mb-4">Post anonymously about local issues, ideas for improvement, or civic experiences.</p>
                
                <form id="post-form" class="space-y-4">
                    <div>
                        <label for="category" class="block text-sm font-medium text-gray-700 mb-1">Topic</label>
                        <select id="category" name="category" required class="w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2.5 border bg-gray-50 text-sm">
                            <option value="" disabled selected>Select a topic...</option>
                            <option value="Local Issue">🚨 Local Issue</option>
                            <option value="Civic Idea">💡 Idea for Improvement</option>
                            <option value="Voting Experience">🗳️ Voting Experience</option>
                            <option value="General Discussion">💬 General Discussion</option>
                        </select>
                    </div>

                    <div>
                        <label for="city" class="block text-sm font-medium text-gray-700 mb-1">City / Region (Optional)</label>
                        <input type="text" id="city" name="city" placeholder="e.g., Mumbai, Maharashtra" class="w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2.5 border bg-gray-50 text-sm">
                    </div>
                    
                    <div>
                        <label for="content" class="block text-sm font-medium text-gray-700 mb-1">Your Message</label>
                        <textarea id="content" name="content" rows="5" required placeholder="What's on your mind? Keep it respectful and constructive." class="w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2.5 border bg-gray-50 text-sm resize-none"></textarea>
                    </div>
                    
                    <button type="submit" id="submit-btn" class="w-full flex justify-center py-2.5 px-4 border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors disabled:opacity-50">
                        Post Anonymously
                    </button>
                    <p class="text-xs text-gray-400 text-center mt-2">Your post is completely anonymous. No IP addresses or accounts are tracked.</p>
                </form>
            </div>
        </div>

        <div class="w-full md:w-2/3">
            <div class="mb-6 flex justify-between items-center">
                <h1 class="text-2xl font-bold text-gray-900">Community Board</h1>
                <div class="relative inline-block text-left">
                    <span class="text-sm text-gray-500 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                        Live updates
                    </span>
                </div>
            </div>

            <div id="posts-container" class="space-y-4">
                <div id="loading-state" class="text-center py-10">
                    <svg class="animate-spin h-8 w-8 text-indigo-500 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <p class="text-gray-500">Connecting to secure board...</p>
                </div>
            </div>
        </div>

    </main>

    <footer class="bg-white border-t border-gray-200 mt-auto">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center">
            <p class="text-gray-400 text-sm">© <span id="year"></span> Civic Voice. A free platform for constructive discourse.</p>
            <div class="mt-4 md:mt-0">
                <a href="#" class="text-gray-400 hover:text-gray-500 text-sm mx-2">Guidelines</a>
                <a href="#" class="text-gray-400 hover:text-gray-500 text-sm mx-2">Privacy Policy</a>
            </div>
        </div>
    </footer>

    <div id="toast-container" class="fixed bottom-5 right-5 z-50 flex-col gap-2"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
        import { getFirestore, collection, addDoc, onSnapshot, serverTimestamp, query, orderBy, limit } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyBsWSKN1V2_1hcfJRT9VzZYWUJHz5_M448",
            authDomain: "civic-voice-37c9e.firebaseapp.com",
            projectId: "civic-voice-37c9e",
            storageBucket: "civic-voice-37c9e.firebasestorage.app",
            messagingSenderId: "214224589082",
            appId: "1:214224589082:web:898e560fbb9ddacaf65ca3",
            measurementId: "G-1275T133E7"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        const form = document.getElementById('post-form');
        const submitBtn = document.getElementById('submit-btn');
        const postsContainer = document.getElementById('posts-container');
        const loadingState = document.getElementById('loading-state');
        const toastContainer = document.getElementById('toast-container');
        document.getElementById('year').textContent = new Date().getFullYear();

        signInAnonymously(auth).catch(err => {
            console.error("Auth failed:", err);
            showToast("Connection error. Refresh page.", "error");
        });

        function showToast(message, type = "success") {
            const colors = { success: "bg-green-600", error: "bg-red-600" };
            const toast = document.createElement('div');
            toast.className = `toast-enter ${colors[type]} text-white px-4 py-3 rounded-lg shadow-lg max-w-sm`;
            toast.textContent = message;
            toastContainer.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function timeAgo(timestamp) {
            if (!timestamp) return "Just now";
            const date = timestamp.toDate ? timestamp.toDate() : new Date(timestamp);
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return "Just now";
            const mins = Math.floor(seconds / 60);
            if (mins < 60) return `${mins}m ago`;
            const hours = Math.floor(mins / 60);
            if (hours < 24) return `${hours}h ago`;
            return `${Math.floor(hours / 24)}d ago`;
        }

        function createPostCard(data) {
            const categoryColors = {
                "Local Issue": "bg-red-100 text-red-700",
                "Civic Idea": "bg-blue-100 text-blue-700", 
                "Voting Experience": "bg-purple-100 text-purple-700",
                "General Discussion": "bg-gray-100 text-gray-700"
            };
            
            const card = document.createElement('div');
            card.className = "bg-white p-5 rounded-xl shadow-sm border-gray-100 hover:shadow-md transition-shadow";
            card.innerHTML = `
                <div class="flex items-start justify-between mb-3">
                    <span class="text-xs font-medium px-2.5 py-1 rounded-full ${categoryColors[data.category] || categoryColors["General Discussion"]}">
                        ${escapeHtml(data.category)}
                    </span>
                    <span class="text-xs text-gray-400">${timeAgo(data.createdAt)}</span>
                </div>
                <p class="text-gray-800 whitespace-pre-wrap mb-3">${escapeHtml(data.content)}</p>
                ${data.city ? `<div class="text-xs text-gray-500 flex items-center gap-1">📍 ${escapeHtml(data.city)}</div>` : ''}
            `;
            return card;
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.textContent = "Posting...";

            const postData = {
                category: form.category.value,
                city: form.city.value.trim(),
                content: form.content.value.trim(),
                createdAt: serverTimestamp()
            };

            try {
                await addDoc(collection(db, "posts"), postData);
                form.reset();
                showToast("Posted anonymously!", "success");
            } catch (err) {
                console.error(err);
                showToast("Failed to post. Check Firestore rules.", "error");
            }
            submitBtn.disabled = false;
            submitBtn.textContent = "Post Anonymously";
        });

        const q = query(collection(db, "posts"), orderBy("createdAt", "desc"), limit(50));
        onSnapshot(q, (snapshot) => {
            loadingState.style.display = 'none';
            postsContainer.innerHTML = '';
            
            if (snapshot.empty) {
                postsContainer.innerHTML = `<div class="text-center py-10 text-gray-400">No posts yet. Be the first to share!</div>`;
                return;
            }

            snapshot.forEach(doc => {
                postsContainer.appendChild(createPostCard(doc.data()));
            });
        }, (err) => {
            console.error(err);
            loadingState.innerHTML = `<p class="text-red-500">Failed to load posts. Check Firestore rules + Anonymous Auth.</p>`;
        });
    </script>
</body>
</html>
